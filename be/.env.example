PORT=3000
JWTSECRET=your-secret
MONGOURI=

# Comma-separated browser origins allowed to call this API with cookies.
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Use "none" when the frontend is on a different site than this API (e.g. Vercel + Railway).
# Requires HTTPS on the API. Sets SameSite=None; Secure on the auth cookie.
COOKIE_SAME_SITE=none

REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_URL_ENDPOINT=
